---
import logoColor from "../../assets/logo/Asset 20RACING LOGO.png";
import { navigation } from "../../data/navigation";
import { whatsappLink } from "../../lib/whatsapp";
---

<footer class="bg-[var(--color-secondary)] text-white">
  <div class="container py-12">

    <!-- TOP -->
    <div class="grid gap-10 md:grid-cols-3 items-start">

    <!-- LOGO + INFO -->
    <div class="space-y-5">
      <img
        src={logoColor.src}
        alt="Autoscuola Racing"
        class="h-12 w-auto object-contain"
      />

      <p class="text-sm text-white/70">
        Autoscuola Racing
        <br />
        Mestre & Favaro Veneto
      </p>

      <div class="space-y-2 border-t border-white/10 pt-5 text-xs leading-6 text-white/55">
        <p class="font-semibold text-white/70">
          Ciemme Srl
        </p>

        <p>
          P.IVA/C.F. 03367550278
          <br />
          Cod. SDI M5UXCR1
        </p>

        <p>
          <span class="font-semibold text-white/65">Sede legale</span>
          <br />
          Via Monte Cervino 23/a
        </p>

        <p>
          <span class="font-semibold text-white/65">Legale rappresentante</span>
          <br />
          Bellato Cristiano
        </p>
      </div>
    </div>

      

      <!-- NAV -->
      <div class="flex flex-col gap-3">
        <p class="text-xs uppercase tracking-[0.12em] text-white/50">
          Navigazione
        </p>

        {navigation.map((item) => (
          <a
            href={item.href}
            class="text-sm font-semibold transition hover:text-[var(--color-primary)]"
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- CONTATTI -->
      <div class="flex flex-col gap-6">
        <p class="text-xs uppercase tracking-[0.12em] text-white/50">
          Contatti
        </p>

        <!-- FAVARO -->
        <div class="space-y-1">
          <p class="text-sm font-semibold text-white">
            Sede di Favaro Veneto
          </p>

          <p class="text-sm text-white/70">
            Via M.te Cervino, 23/a<br />
            30173 Favaro Veneto (VE)
          </p>

          <a
            href="tel:+39041630163"
            class="text-sm text-white/80 transition hover:text-[var(--color-primary)]"
            data-track="phone_click"
            data-location="favaro"
            data-section="footer"
          >
            +39 041 630163
          </a>

          <p class="text-xs leading-5 text-white/55">
            Lunedi - Venerdi: 9:00-12:00 / 16:00-19:00
          </p>

          <a
            href={whatsappLink(
              "393755310899",
              "Ciao Autoscuola Racing Favaro, vorrei ricevere informazioni."
            )}
            class="text-sm text-white/80 transition hover:text-[var(--color-primary)]"
            data-track="whatsapp_click"
            data-location="favaro"
            data-section="footer"
          >
            WhatsApp Favaro
          </a>
        </div>

        <!-- SALZANO -->
        <div class="space-y-1">
          <p class="text-sm font-semibold text-white">
            Sede di Salzano
          </p>

          <p class="text-sm text-white/70">
            Via A. De Gasperi, 84<br />
            30030 Salzano (VE)
          </p>

          <a
            href="tel:+390415746510"
            class="text-sm text-white/80 transition hover:text-[var(--color-primary)]"
            data-track="phone_click"
            data-location="salzano"
            data-section="footer"
          >
            +39 041 5746510
          </a>

          <p class="text-xs leading-5 text-white/55">
            Lunedi - Venerdi: 9:00-12:00 / 16:30-19:00
          </p>

          <a
            href={whatsappLink(
              "393755184936",
              "Ciao Autoscuola Racing Salzano, vorrei ricevere informazioni."
            )}
            class="text-sm text-white/80 transition hover:text-[var(--color-primary)]"
            data-track="whatsapp_click"
            data-location="salzano"
            data-section="footer"
          >
            WhatsApp Salzano
          </a>
        </div>

        <!-- LINK CONTATTI -->
        <a
          href="/contatti"
          class="pt-2 text-sm font-semibold transition hover:text-[var(--color-primary)]"
          data-track="cta_click"
          data-location="footer"
          data-section="contacts"
        >
          Vai alla pagina contatti
        </a>
      </div>
    </div>
    <!-- DIVIDER -->
    <div class="my-10 h-px bg-white/10"></div>

    <!-- BOTTOM -->
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <p class="text-xs text-white/60">
        © 2026 Autoscuola Racing. Tutti i diritti riservati.
      </p>

      <div class="flex flex-wrap gap-6 text-xs">
        <a
          href="/privacy-policy"
          class="hover:text-[var(--color-primary)]"
        >
          Privacy Policy
        </a>

        <a
          href="/cookie-policy"
          class="hover:text-[var(--color-primary)]"
        >
          Cookie Policy
        </a>

        <a
          href="#"
          class="lb-cs-settings-link hover:text-[var(--color-primary)]"
        >
          Aggiorna preferenze cookie
        </a>
      </div>
    </div>

  </div>
</footer>
