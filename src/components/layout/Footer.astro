---
import { site } from "../../data/site";
---

<footer class="section section-light border-t border-black/10">
  <div class="container grid gap-10 md:grid-cols-3">
    <div>
      <h2 class="text-lg font-bold">{site.name}</h2>
      <p class="mt-3 text-sm leading-6 text-black/70">
        Autoscuola e scuola nautica con sedi a Favaro Veneto e Salzano.
      </p>
    </div>

    <div>
      <h3 class="text-sm font-bold uppercase tracking-wide">Sede Favaro Veneto</h3>
      <p class="mt-3 text-sm leading-6 text-black/70">
        {site.addressFavaro}<br />
        Tel. {site.phoneFavaro}<br />
        {site.emailFavaro}
      </p>
    </div>

    <div>
      <h3 class="text-sm font-bold uppercase tracking-wide">Sede Salzano</h3>
      <p class="mt-3 text-sm leading-6 text-black/70">
        {site.addressSalzano}<br />
        Tel. {site.phoneSalzano}<br />
        {site.emailSalzano}
      </p>
    </div>
  </div>

  <div class="container mt-10 border-t border-black/10 pt-6 text-sm text-black/60">
    <p>{site.legalName} · P.IVA 03367550278</p>
  </div>
</footer>