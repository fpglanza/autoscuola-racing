---
import { navigation } from "../../data/navigation";
import { patentiData } from "../../data/patenti";
import logoColor from "../../assets/logo/Asset 20RACING LOGO.png";

const normalizePath = (path: string) => {
  if (!path || path === "/") return "/";
  return path.endsWith("/") ? path.slice(0, -1) : path;
};

const currentPath = normalizePath(Astro.url.pathname);

const desktopNavigation = navigation.filter((item) => item.href !== "/");

const leftNavigation = [
  navigation.find((item) => item.href === "/"),
  desktopNavigation.find((item) => item.href === "/chi-siamo"),
  desktopNavigation.find((item) => item.href === "/patente-auto"),
].filter(Boolean);

const rightNavigation = [
  desktopNavigation.find((item) => item.href === "/pratiche"),
  desktopNavigation.find((item) => item.href === "/patenti"),
  desktopNavigation.find((item) => item.href === "/contatti"),
].filter(Boolean);

const isActive = (href: string) => currentPath === normalizePath(href);
---

<header class="fixed inset-x-0 top-0 z-50 bg-transparent">
  <div class="container py-4 md:py-5">
    <div class="hidden lg:block">
      <div class="rounded-full bg-[var(--color-secondary)] px-10 py-4 shadow-[0_16px_40px_rgba(0,0,0,0.20)]">
        <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-8">
          <nav class="flex items-center justify-end gap-8">
            {leftNavigation.map((item) => (
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class="relative text-[12px] font-bold uppercase tracking-[0.08em] transition-transform duration-200 ease-out hover:translate-x-[5px]"
                style="color: #D4FF00;"
              >
                {item.label}
                <span
                  class:list={[
                    "absolute left-0 top-full z-10 mt-1 h-[2px] rounded-full bg-[#D4FF00] transition-all duration-200",
                    isActive(item.href) ? "w-full opacity-100" : "w-0 opacity-0",
                  ]}
                />
              </a>
            ))}
          </nav>

          <a href="/" class="mx-3 flex items-center justify-center">
            <img
              src={logoColor.src}
              alt="Autoscuola Racing"
              class="h-11 w-auto"
            />
          </a>

          <nav class="flex items-center justify-start gap-8">
            {rightNavigation.map((item) => {
              const isPatenti = item.href === "/patenti";

              return isPatenti ? (
                <div class="group relative">
                  <a
                    href={item.href}
                    aria-current={isActive(item.href) ? "page" : undefined}
                    class="relative text-[12px] font-bold uppercase tracking-[0.08em] transition-transform duration-200 ease-out hover:translate-x-[5px]"
                    style="color: #D4FF00;"
                  >
                    {item.label}
                    <span
                      class:list={[
                        "absolute left-0 top-full z-10 mt-1 h-[2px] rounded-full bg-[#D4FF00] transition-all duration-200",
                        isActive(item.href) ? "w-full opacity-100" : "w-0 opacity-0",
                      ]}
                    />
                  </a>

                  <div class="pointer-events-none absolute left-0 top-full pt-4 opacity-0 transition-all duration-200 group-hover:pointer-events-auto group-hover:opacity-100">
                    <div class="min-w-[260px] rounded-2xl border border-black/5 bg-white p-4 shadow-[0_16px_40px_rgba(0,0,0,0.10)]">
                      <div class="flex flex-col gap-3">
                        {patentiData.items.map((patente) => (
                          <a
                            href={`/patenti#${patente.slug}`}
                            class="text-sm font-semibold text-[var(--color-secondary)] transition hover:translate-x-[4px]"
                          >
                            {patente.title}
                          </a>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              ) : (
                <a
                  href={item.href}
                  aria-current={isActive(item.href) ? "page" : undefined}
                  class="relative text-[12px] font-bold uppercase tracking-[0.08em] transition-transform duration-200 ease-out hover:translate-x-[5px]"
                  style="color: #D4FF00;"
                >
                  {item.label}
                  <span
                    class:list={[
                      "absolute left-0 top-full z-10 mt-1 h-[2px] rounded-full bg-[#D4FF00] transition-all duration-200",
                      isActive(item.href) ? "w-full opacity-100" : "w-0 opacity-0",
                    ]}
                  />
                </a>
              );
            })}
          </nav>
        </div>
      </div>
    </div>

    <div class="lg:hidden">
      <div class="flex items-center justify-between rounded-full bg-[var(--color-secondary)] px-5 py-3 shadow-[0_16px_40px_rgba(0,0,0,0.20)]">
        <a href="/" class="flex items-center">
          <img
            src={logoColor.src}
            alt="Autoscuola Racing"
            class="h-8 w-auto"
          />
        </a>

        <button
          id="menu-toggle"
          type="button"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10"
          aria-label="Apri menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="flex flex-col gap-1.5">
            <span class="block h-0.5 w-5" style="background-color: #D4FF00;"></span>
            <span class="block h-0.5 w-5" style="background-color: #D4FF00;"></span>
            <span class="block h-0.5 w-5" style="background-color: #D4FF00;"></span>
          </span>
        </button>
      </div>

      <div
        id="mobile-menu"
        class="mt-3 hidden overflow-hidden rounded-3xl border border-black/5 bg-white shadow-[0_16px_40px_rgba(0,0,0,0.08)]"
      >
        <nav class="flex flex-col p-5">
          {navigation.map((item) => {
            const isPatenti = item.href === "/patenti";

            return isPatenti ? (
              <div class="border-b border-black/5 py-4 last:border-0">
                <button
                  type="button"
                  data-mobile-patenti-toggle
                  aria-expanded={isActive(item.href) ? "true" : "false"}
                  aria-controls="mobile-patenti-submenu"
                  class="flex w-full items-center justify-between text-left text-base font-bold uppercase tracking-[0.08em] text-[var(--color-secondary)]"
                >
                  <span
                    class:list={[
                      isActive(item.href)
                        ? "underline decoration-[var(--color-primary)] decoration-2 underline-offset-8"
                        : "",
                    ]}
                  >
                    {item.label}
                  </span>

                  <span
                    data-mobile-patenti-icon
                    class:list([
                      "transition-transform duration-200",
                      isActive(item.href) ? "rotate-180" : "",
                    ]}
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-5 w-5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  </span>
                </button>

                <div
                  id="mobile-patenti-submenu"
                  class:list={[
                    "pt-4",
                    isActive(item.href) ? "" : "hidden",
                  ]}
                >
                  <div class="flex flex-col gap-3 pl-3">
                    <a
                      href="/patenti"
                      class="text-sm font-semibold uppercase tracking-[0.06em] text-[var(--color-secondary)]/80"
                    >
                      Tutte le patenti
                    </a>

                    {patentiData.items.map((patente) => (
                      <a
                        href={`/patenti#${patente.slug}`}
                        class="text-sm font-semibold text-[var(--color-secondary)]/80"
                      >
                        {patente.title}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={[
                  "border-b border-black/5 py-4 text-base font-bold uppercase tracking-[0.08em] last:border-0",
                  isActive(item.href)
                    ? "text-[var(--color-secondary)] underline decoration-[var(--color-primary)] decoration-2 underline-offset-8"
                    : "text-[var(--color-secondary)]",
                ]}
              >
                {item.label}
              </a>
            );
          })}
        </nav>

        <div class="px-5 pb-5 pt-2">
          <a
            href="/contatti"
            class="btn-racing-primary w-full justify-center"
            data-track="cta_click"
            data-location="header"
            data-section="mobile-menu"
          >
            contattaci
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    const isExpanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!isExpanded));
    menu?.classList.toggle("hidden");
  });

  const mobilePatentiToggle = document.querySelector("[data-mobile-patenti-toggle]");
  const mobilePatentiSubmenu = document.getElementById("mobile-patenti-submenu");
  const mobilePatentiIcon = document.querySelector("[data-mobile-patenti-icon]");

  mobilePatentiToggle?.addEventListener("click", () => {
    const isExpanded = mobilePatentiToggle.getAttribute("aria-expanded") === "true";
    mobilePatentiToggle.setAttribute("aria-expanded", String(!isExpanded));
    mobilePatentiSubmenu?.classList.toggle("hidden");

    if (mobilePatentiIcon instanceof HTMLElement) {
      mobilePatentiIcon.style.transform = isExpanded ? "rotate(0deg)" : "rotate(180deg)";
    }
  });
</script>
