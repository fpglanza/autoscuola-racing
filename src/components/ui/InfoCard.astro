---
interface Props {
  title: string;
  text: string;
  href?: string;
  ctaLabel?: string;
  bordered?: boolean;
}

const {
  title,
  text,
  href,
  ctaLabel = "Approfondisci",
  bordered = false,
} = Astro.props;
---

<article class:list={[
  "rounded-3xl bg-white p-6",
  bordered && "border border-black/10",
]}>
  <h3 class="text-lg font-bold">{title}</h3>
  <p class="mt-3 text-sm leading-6 text-black/70">{text}</p>

  {href && (
    <div class="mt-5">
      <a
        href={href}
        class="btn-secondary"
        data-track="cta_click"
        data-location="info-card"
        data-section={title}
      >{ctaLabel}</a>
    </div>
  )}
</article>
