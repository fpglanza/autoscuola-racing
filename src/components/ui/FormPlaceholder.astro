---
interface Props {
  title: string;
  body: string;
  fields: string[];
}

const { title, body, fields } = Astro.props;
---

<section class="rounded-3xl border border-black/10 bg-white p-6">
  <h3 class="text-2xl font-bold">{title}</h3>
  <p class="mt-4 text-sm leading-6 text-black/70">{body}</p>

  <div class="mt-6 grid gap-3 md:grid-cols-2">
    {fields.map((field) => (
      <div class="rounded-2xl border border-dashed border-black/15 px-4 py-3 text-sm text-black/50">
        {field}
      </div>
    ))}
  </div>
</section>