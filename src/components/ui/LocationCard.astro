---
interface Props {
  name: string;
  city: string;
  address: string;
  phone: string;
  email: string;
  whatsapp?: string;
  notes?: string;
}

const { name, city, address, phone, email, whatsapp = "#", notes } = Astro.props;
---

<article class="rounded-3xl border border-black/10 bg-white p-6">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-black/50">{city}</p>
  <h3 class="mt-2 text-xl font-bold">{name}</h3>

  {notes && <p class="mt-2 text-sm text-black/60">{notes}</p>}

  <div class="mt-5 space-y-2 text-sm leading-6 text-black/70">
    <p>{address}</p>
    <p>Tel. {phone}</p>
    <p>{email}</p>
  </div>

  <div class="mt-6 flex flex-wrap gap-3">
    <a href={`tel:${phone.replaceAll(" ", "")}`} class="btn-secondary">Chiama</a>
    <a href={`mailto:${email}`} class="btn-secondary">Email</a>
    <a href={whatsapp} class="btn-primary">WhatsApp</a>
  </div>
</article>