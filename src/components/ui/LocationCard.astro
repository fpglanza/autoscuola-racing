---
import { whatsappLink } from "../../lib/whatsapp";

interface Props {
  name: string;
  city: string;
  address: string;
  phone: string;
  email: string;
  whatsapp?: string;
  notes?: string;
  mapUrl?: string;
}

const {
  name,
  city,
  address,
  phone,
  email,
  whatsapp = whatsappLink(
    "393755310899",
    "Ciao Autoscuola Racing, vorrei ricevere informazioni."
  ),
  notes,
  mapUrl = "/contatti",
} = Astro.props;
---

<article class="rounded-3xl border border-black/10 bg-white p-6">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-black/50">{city}</p>
  <h3 class="mt-2 text-xl font-bold">{name}</h3>

  {notes && <p class="mt-2 text-sm text-black/60">{notes}</p>}

  <div class="mt-5 space-y-2 text-sm leading-6 text-black/70">
    <p>{address}</p>
    <p>Tel. {phone}</p>
    <p>{email}</p>
  </div>

  <div class="mt-6 flex flex-wrap gap-3">
    <a
      href={`tel:${phone.replaceAll(" ", "")}`}
      class="btn-secondary"
      data-track="phone_click"
      data-location={city}
      data-section="location-card"
    >Chiama</a>
    <a
      href={`mailto:${email}`}
      class="btn-secondary"
      data-track="email_click"
      data-location={city}
      data-section="location-card"
    >Email</a>
    <a
      href={whatsapp}
      class="btn-racing-primary"
      data-track="whatsapp_click"
      data-location={city}
      data-section="location-card"
    >WhatsApp</a>
    <a
      href={mapUrl}
      class="btn-secondary"
      data-track="cta_click"
      data-location={city}
      data-section="location-card"
    >Mappa</a>
  </div>
</article>
