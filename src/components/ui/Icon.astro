---
interface Props {
  src: string;
  alt?: string;
  class?: string;
}

const { src, alt = "", class: className = "" } = Astro.props;
const encodedSrc = src.replaceAll(" ", "%20");
---

<span
  class:list={["inline-block shrink-0 bg-current", className]}
  role={alt ? "img" : undefined}
  aria-label={alt || undefined}
  aria-hidden={alt ? undefined : "true"}
  style={`--icon-url: url("${encodedSrc}"); -webkit-mask: var(--icon-url) center / contain no-repeat; mask: var(--icon-url) center / contain no-repeat;`}
/>
