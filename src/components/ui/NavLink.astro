---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
const isActive = Astro.url.pathname === href;
---

<a
  href={href}
  class:list={[
    "text-sm font-medium transition",
    isActive
      ? "text-[var(--racing-dark)]"
      : "text-[var(--racing-dark)]/70 hover:text-[var(--racing-dark)]",
  ]}
  aria-current={isActive ? "page" : undefined}
>
  {label}
</a>