---
interface Props {
  name: string;
  role: string;
  bio: string;
}

const { name, role, bio } = Astro.props;
---

<article class="rounded-3xl border border-black/10 bg-white p-6">
  <div class="flex h-14 w-14 items-center justify-center rounded-full bg-[var(--racing-light)] text-lg font-bold">
    {name.charAt(0)}
  </div>

  <h3 class="mt-4 text-xl font-bold">{name}</h3>
  <p class="mt-1 text-sm font-medium text-[var(--racing-green)]">{role}</p>
  <p class="mt-4 text-sm leading-6 text-black/70">{bio}</p>
</article>