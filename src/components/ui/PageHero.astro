---
interface Cta {
  label: string;
  href: string;
}

interface Props {
  label?: string;
  heading: string;
  intro: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  imageAlt?: string;
  imageSrc?: string;
  placeholderText?: string;
}

const {
  label,
  heading,
  intro,
  primaryCta,
  secondaryCta,
  imageAlt = "",
  imageSrc,
  placeholderText = "Placeholder immagine",
} = Astro.props;
---

<section class="relative overflow-hidden py-14 md:py-20">
  <div class="container">
    <div class="grid items-center gap-10 md:grid-cols-[1.05fr_0.95fr] md:gap-14">
      <div class="max-w-2xl">
        {label && (
          <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.22em] text-[var(--color-secondary)]/70 md:text-xs">
            {label}
          </p>
        )}

        <h1 class="text-[32px] leading-[0.95] text-[var(--color-secondary)] md:text-[48px] xl:text-[64px]">
          {heading}
        </h1>

        <div class="mt-6 max-w-xl space-y-4 text-base leading-7 text-[var(--color-text)]/85 md:text-lg md:leading-8">
          {intro.split("\n").map((paragraph) => <p>{paragraph}</p>)}
        </div>

        {(primaryCta || secondaryCta) && (
          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            {primaryCta && (
              <a href={primaryCta.href} class="btn-racing-primary">
                {primaryCta.label}
              </a>
            )}

            {secondaryCta && (
              <a href={secondaryCta.href} class="btn-secondary">
                {secondaryCta.label}
              </a>
            )}
          </div>
        )}
      </div>

      <div class="relative">
        <div class="absolute inset-0 translate-x-4 translate-y-4 rounded-[28px] bg-[var(--color-accent)]/12 blur-2xl"></div>

        <div class="relative overflow-hidden rounded-[28px] border border-[var(--color-secondary)]/8 bg-white p-5 shadow-[0_20px_60px_rgba(18,19,93,0.08)] md:p-8">
          <div class="absolute right-4 top-4 h-16 w-16 rounded-full bg-[var(--color-primary)]/60 blur-2xl"></div>
          <div class="absolute bottom-4 left-4 h-20 w-20 rounded-full bg-[var(--color-accent)]/10 blur-2xl"></div>

          <div class="relative flex min-h-[260px] items-center justify-center rounded-[20px] bg-[linear-gradient(135deg,rgba(212,255,0,0.10),rgba(33,36,189,0.04))] p-6 md:min-h-[340px]">
            {imageSrc ? (
              <img
                src={imageSrc}
                alt={imageAlt}
                class="max-h-[280px] w-full object-contain md:max-h-[360px]"
              />
            ) : (
              <div class="text-center text-sm font-medium uppercase tracking-[0.14em] text-[var(--color-secondary)]/45">
                {placeholderText}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>