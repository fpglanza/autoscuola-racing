---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../lib/content";
import { homeData } from "../data/home";
import logoFull from "../assets/logo/logo-racing-full.png";
import PageHero from "../components/ui/PageHero.astro";
import InfoCard from "../components/ui/InfoCard.astro";

const page = await getPageContent("home");
const { title, description } = page.data;
---

  <BaseLayout title={title} description={description}>
    <PageHero
    label={homeData.territoryLabel}
    heading={homeData.hero.heading}
    intro={homeData.hero.intro}
    primaryCta={homeData.hero.primaryCta}
    secondaryCta={homeData.hero.secondaryCta}
    imageSrc={logoFull.src}
    imageAlt="Autoscuola Racing"
  />

  <section class="section section-light">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold">{homeData.locationsIntro.title}</h2>
        <p class="mt-4 text-lg leading-8 text-black/70">{homeData.locationsIntro.body}</p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {homeData.locations.map((item) => (
          <article class="rounded-3xl bg-white p-6">
            <h3 class="text-xl font-bold">{item.title}</h3>
            <p class="mt-4 text-sm leading-6 text-black/70">{item.text}</p>
          </article>
        ))}
      </div>

      <p class="mt-8 max-w-3xl text-base leading-7 text-black/70">
        {homeData.serviceNote}
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold">{homeData.approach.title}</h2>
        <p class="mt-4 text-lg leading-8 text-black/70">{homeData.approach.body}</p>
        <div class="mt-6">
          <a href={homeData.approach.cta.href} class="btn-secondary">
            {homeData.approach.cta.label}
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold">{homeData.paths.title}</h2>
        <p class="mt-4 text-lg leading-8 text-black/70">{homeData.paths.intro}</p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {homeData.paths.items.map((item) => (
          <article class="rounded-3xl bg-white p-6">
            <h3 class="text-lg font-bold">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-black/70">{item.text}</p>
            <div class="mt-5">
              <a href={item.href} class="btn-secondary">Approfondisci</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">{homeData.whyUs.title}</h2>
      <p class="mt-4 text-lg leading-8 text-black/70">{homeData.whyUs.body}</p>
    </div>
  </section>

  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">{homeData.territory.title}</h2>
      <p class="mt-4 text-lg leading-8 text-black/70">{homeData.territory.body}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold">{homeData.practicalInfo.title}</h2>
        <p class="mt-4 text-lg leading-8 text-black/70">{homeData.practicalInfo.body}</p>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {homeData.practicalInfo.items.map((item) => (
          <div class="rounded-2xl border border-black/10 p-4 text-sm font-medium text-black/70">
            {item}
          </div>
        ))}
      </div>

      <div class="mt-8">
        <a href={homeData.practicalInfo.primaryCta.href} class="btn-primary">
          {homeData.practicalInfo.primaryCta.label}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>