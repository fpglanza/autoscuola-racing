---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../lib/content";
import { homeData } from "../data/home";
import heroBg from "../assets/logo/Hero Banner Home R.jpg";
import heroLogo from "../assets/logo/6x/Asset 13.png";

const page = await getPageContent("home");
const { title, description } = page.data;
---

<BaseLayout title={title} description={description}>
  <!-- HERO -->
   <section class="relative h-screen w-full overflow-hidden">
      <img
        src={heroBg.src}
        alt="Autoscuola Racing"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/40"></div>

      <div class="relative z-10 flex h-full items-center justify-center text-center">
        <div class="container">
          <div class="mx-auto flex max-w-4xl flex-col items-center pt-24 pb-10">
            <p class="mb-2 max-w-[900px] text-center text-[10px] font-bold uppercase leading-none tracking-[0.18em] text-white md:text-xs">
              {homeData.hero.label}
            </p>
            <h1
              class="heading-hero text-[clamp(2.5rem,6vw,6rem)]"
            >
              {homeData.hero.heading}
            </h1>
            <div class="mt-5 max-w-2xl space-y-3 text-sm leading-6 text-white md:text-base md:leading-7">
              {homeData.hero.intro.map((paragraph) => <p>{paragraph}</p>)}
            </div>
            <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
              <a href={homeData.hero.cta.href} class="btn-racing-lime">
                {homeData.hero.cta.label}
              </a>
              <a
                href="/patente-auto"
                class="btn-racing-ghost-lime"
              >
                scopri patente auto
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

  <!-- AUTOSCUOLA A FAVARO E SALZANO -->
  <section class="section">
    <div class="container max-w-4xl">
      <h2 class="text-center text-[30px] uppercase leading-tight text-[var(--color-secondary)] md:text-[40px]">
        {homeData.locationsIntro.title}
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-center text-base leading-7 text-[var(--color-text)]/80 md:text-lg md:leading-8">
        {homeData.locationsIntro.body}
      </p>

      <div class="mt-12 grid gap-8 md:grid-cols-2 md:gap-10">
        {homeData.locations.map((item) => (
          <article class="border-t border-black/10 pt-6">
            <h3 class="text-[24px] uppercase leading-[1.15] text-[var(--color-secondary)] md:text-[26px]">
              {item.title}
            </h3>

            <p class="mt-5 text-sm leading-7 text-[var(--color-text)]/80 md:text-base">
              {item.text}
            </p>
          </article>
        ))}
      </div>

      <p class="mx-auto mt-10 max-w-3xl text-center text-base leading-7 text-[var(--color-text)]/80 md:text-lg md:leading-8">
        {homeData.serviceNote}
      </p>
    </div>
  </section>

  <!-- IL NOSTRO APPROCCIO -->
  <section class="section">
    <div class="container max-w-4xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-4 text-xs uppercase tracking-[0.25em] text-[var(--color-secondary)]/50">
          {homeData.approach.label}
        </p>

        <h2 class="text-[30px] uppercase leading-tight text-[var(--color-secondary)] md:text-[40px]">
          {homeData.approach.title}
        </h2>
      </div>

      <div class="mx-auto mt-8 max-w-3xl space-y-5 text-base leading-7 text-[var(--color-text)]/80 md:text-lg md:leading-8">
        {homeData.approach.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <div class="mt-8 text-center">
        <a href={homeData.approach.cta.href} class="btn-racing-primary">
          {homeData.approach.cta.label}
        </a>
      </div>
    </div>
  </section>

  <!-- I PERCORSI -->
  <section class="section">
    <div class="container max-w-5xl">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-[30px] uppercase leading-tight text-[var(--color-secondary)] md:text-[40px]">
          {homeData.paths.title}
        </h2>

        <p class="mt-6 text-base leading-7 text-[var(--color-text)]/80 md:text-lg md:leading-8">
          {homeData.paths.intro}
        </p>
      </div>

      <div class="mt-12 grid gap-10 md:grid-cols-3">
        {homeData.paths.items.map((item, index) => (
          <article class="flex h-full min-h-[380px] flex-col border-t border-black/10 pt-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-secondary)]/50">
              {String(index + 1).padStart(2, "0")}
            </p>

            <h3 class="mt-4 text-[24px] uppercase leading-[1.15] text-[var(--color-secondary)] md:text-[28px]">
              {item.title}
            </h3>

            <p class="mt-4 text-sm leading-7 text-[var(--color-text)]/80 md:text-base">
              {item.text}
            </p>

            <!-- spazio controllato + allineamento -->
            <div class="mt-auto pt-6 flex justify-center">
              <a href={item.href} class="btn-secondary">
                {item.ctaLabel}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PERCHÉ SCEGLIERE IL METODO RACING -->
  <section class="section">
    <div class="container max-w-4xl">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-center text-[30px] uppercase leading-tight text-[var(--color-secondary)] md:text-[40px]">
          {homeData.whyUs.title}
        </h2>

        <div class="mt-8 space-y-5 text-base leading-7 text-[var(--color-text)]/80 md:text-lg md:leading-8">
          {homeData.whyUs.body.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </div>
  </section>

  <!-- STORIA E TERRITORIO -->
  <section class="section">
    <div class="container max-w-4xl">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-center text-[30px] uppercase leading-tight text-[var(--color-secondary)] md:text-[40px]">
          {homeData.territory.title}
        </h2>

        <div class="mt-8 space-y-5 text-base leading-7 text-[var(--color-text)]/80 md:text-lg md:leading-8">
          {homeData.territory.body.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </div>
  </section>

  <!-- INFO PRATICHE E CONTATTI -->
  <section class="section pb-16">
    <div class="container max-w-5xl">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-[30px] uppercase leading-tight text-[var(--color-secondary)] md:text-[40px]">
          {homeData.practicalInfo.title}
        </h2>

        <p class="mt-6 text-base leading-7 text-[var(--color-text)]/80 md:text-lg md:leading-8">
          {homeData.practicalInfo.body}
        </p>
      </div>

      <div class="mt-12 grid gap-10 md:grid-cols-2">
        {homeData.practicalInfo.locations.map((item, index) => (
          <article class="border-t border-black/10 pt-6">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-secondary)]/50">
              {index === 0 ? "Sede 01" : "Sede 02"}
            </p>

            <p class="mt-4 text-base leading-8 text-[var(--color-text)]/80">
              {item}
            </p>
          </article>
        ))}
      </div>

      <div class="mx-auto mt-12 max-w-4xl border-t border-black/10 pt-6">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-secondary)]/50">
          Visite mediche in sede
        </p>

        <p class="mt-4 text-base leading-8 text-[var(--color-text)]/80">
          {homeData.practicalInfo.medical}
        </p>
      </div>

      <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
        {homeData.practicalInfo.ctas.map((cta) => (
          <a
            href={cta.href}
            class={cta.variant === "primary" ? "btn-racing-primary" : "btn-secondary"}
          >
            {cta.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>