---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../lib/content";

const page = await getPageContent("home");
const { title, description, heading, intro } = page.data;
---

<BaseLayout title={title} description={description}>
  <section class="section">
    <div class="container">
      <div class="grid items-center gap-10 md:grid-cols-2">
        <div>
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-black/60">
            Favaro Veneto · Salzano
          </p>

          <h1 class="max-w-xl text-4xl font-bold leading-tight md:text-5xl">
            {heading}
          </h1>

          <p class="mt-6 max-w-xl text-lg leading-8 text-black/70">
            {intro}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/patente-auto" class="btn-primary">Scopri Patente Auto</a>
            <a href="/contatti" class="btn-secondary">Contattaci</a>
          </div>
        </div>

        <div class="rounded-3xl bg-[var(--racing-light)] p-10">
          <div class="flex aspect-[4/3] items-center justify-center rounded-2xl border border-dashed border-black/15 bg-white text-center text-black/40">
            Placeholder hero immagine
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold">Un metodo chiaro e accompagnato</h2>
        <p class="mt-4 text-lg leading-8 text-black/70">
          Ti aiutiamo a costruire un percorso serio, leggibile e progressivo, senza fretta inutile e senza approcci impersonali.
        </p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <div class="rounded-3xl bg-white p-6">
          <h3 class="text-lg font-bold">Comprensione</h3>
          <p class="mt-3 text-sm leading-6 text-black/70">
            La teoria viene affrontata per capire davvero, non solo per memorizzare.
          </p>
        </div>

        <div class="rounded-3xl bg-white p-6">
          <h3 class="text-lg font-bold">Progressione</h3>
          <p class="mt-3 text-sm leading-6 text-black/70">
            Ogni percorso segue tempi coerenti con il livello reale dello studente.
          </p>
        </div>

        <div class="rounded-3xl bg-white p-6">
          <h3 class="text-lg font-bold">Accompagnamento</h3>
          <p class="mt-3 text-sm leading-6 text-black/70">
            L’obiettivo è arrivare pronti all’esame, con una preparazione solida.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>