---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/ui/Icon.astro";
import { getPageContent } from "../lib/content";
import { praticheData } from "../data/pratiche";
import { icons } from "../lib/icons";
import praticheHeroBg from "../assets-optimized/logo/Ragazza patente B.webp";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";

const page = await getPageContent("pratiche");
const { title, description } = page.data;

const renewalItems = praticheData.renewal.items.map((item) => {
  const [rawTitle, ...rest] = item.split(":");
  return {
    title: rawTitle?.trim() ?? "",
    body: rest.join(":").trim(),
  };
});

const duplicateItems = praticheData.duplicates.items.map((item) => {
  const [rawTitle, ...rest] = item.split(":");
  return {
    title: rawTitle?.trim() ?? "",
    body: rest.join(":").trim(),
  };
});
---

<BaseLayout title={title} description={description}>
  <!-- HERO -->
  <section class="relative min-h-screen w-full overflow-hidden bg-[#05091f]">
    <img
      src={praticheHeroBg.src}
      alt="Pratiche patente Autoscuola Racing"
      class="absolute inset-0 h-full w-full object-cover"
    />

    <!-- Overlay coerente con homepage -->
    <div class="absolute inset-0 hero-overlay-main"></div>

    <!-- Overlay laterale per leggibilità testo a sinistra -->
    <div class="absolute inset-0 hero-overlay-side"></div>

    <div class="relative z-10 flex min-h-screen items-center">
      <div class="container">
        <div class="max-w-3xl pt-28 pb-16 text-left">
          <p class="mb-3 text-[10px] font-bold uppercase leading-none tracking-[0.18em] text-white/80 md:text-xs">
            Pratiche patente
          </p>

          <h1 class="heading-hero text-left text-[clamp(2.7rem,6vw,6rem)]">
            {praticheData.hero.heading}
          </h1>

          <div class="mt-6 max-w-2xl text-left text-sm leading-6 text-white/85 md:text-base md:leading-7">
            <p>{praticheData.hero.intro}</p>
          </div>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href={praticheData.hero.cta.href}
              class="btn-racing-lime"
              data-track="cta_click"
              data-location="pratiche"
              data-section="hero"
            >
              {praticheData.hero.cta.label}
            </a>

            <a
              href="#rinnovo"
              class="btn-racing-ghost-lime"
              data-track="cta_click"
              data-location="pratiche"
              data-section="hero"
            >
              scopri le pratiche
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Breadcrumbs />
  <!-- RINNOVO -->
  <section id="rinnovo" class="section scroll-mt-[140px] overflow-hidden">
    <div class="container max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold">
          {praticheData.renewal.title}
        </h2>

        <p class="mt-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
          {praticheData.renewal.body}
        </p>
      </div>

      <div class="relative mt-14">
        <div class="absolute left-0 right-0 top-10 hidden border-t border-dashed border-[#12135D]/15 xl:block"></div>

        <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3 xl:gap-10">
          {renewalItems.map((item, index) => (
            <article class="relative text-center">
              <div
                class:list={[
                  "relative z-[1] mx-auto flex h-20 w-20 items-center justify-center rounded-[22px] shadow-[0_20px_50px_rgba(18,19,93,0.12)]",
                  index % 2 === 0
                    ? "bg-[#D4FF00] text-[#12135D]"
                    : "bg-[#12135D] text-white",
                ]}
              >
                {index === 0 && (
                  <Icon src={icons.podium} class="h-9 w-9" />
                )}

                {index === 1 && (
                  <Icon src={icons.fire} class="h-9 w-9" />
                )}

                {index === 2 && (
                  <Icon src={icons.gear} class="h-9 w-9" />
                )}
              </div>

              <h3 class="mt-6 text-xl font-bold text-[#12135D]">
                {item.title}
              </h3>

              <p class="mx-auto mt-3 max-w-[18rem] text-sm leading-7 text-[#2C3E50]/80 md:text-[15px]">
                {item.body}
              </p>
            </article>
          ))}
        </div>
      </div>

      <div class="mt-10 text-center">
        <a
          href={praticheData.renewal.cta}
          class="btn-racing-primary"
          data-track="cta_click"
          data-location="pratiche"
          data-section="renewal"
        >
          Contattaci
        </a>
      </div>
    </div>
  </section>

  <!-- CASI SPECIALI -->
  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">
        {praticheData.medical.title}
      </h2>

      <div class="mt-6 space-y-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
        <p>{praticheData.medical.body}</p>
      </div>

      <div class="mt-8">
        <a
          href={praticheData.medical.cta}
          class="btn-racing-primary"
          data-track="cta_click"
          data-location="pratiche"
          data-section="medical"
        >
          Contattaci
        </a>
      </div>
    </div>
  </section>

  <!-- DUPLICATI E PATENTE INTERNAZIONALE -->
  <section class="section overflow-hidden">
    <div class="container max-w-5xl">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold">
          {praticheData.duplicates.title}
        </h2>
      </div>

      <div class="mx-auto mt-10 grid max-w-5xl gap-5 md:grid-cols-2">
        {duplicateItems.map((item, index) => (
          <article class="group flex h-full flex-col rounded-[28px] border border-[#12135D]/10 bg-white p-6 shadow-[0_18px_45px_rgba(18,19,93,0.08)] transition-transform duration-300 hover:-translate-y-1">
            <div
              class:list={[
                "mb-5 h-1.5 w-14 rounded-full transition-all duration-300 group-hover:w-24",
                index % 2 === 0 ? "bg-[#D4FF00]" : "bg-[#12135D]",
              ]}
            ></div>

            <h3 class="text-lg font-bold text-[#12135D]">
              {item.title}
            </h3>

            <p class="mt-3 text-sm leading-7 text-black/70 md:text-[15px]">
              {item.body}
            </p>
          </article>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a
          href={praticheData.duplicates.cta}
          class="btn-racing-primary"
          data-track="cta_click"
          data-location="pratiche"
          data-section="duplicates"
        >
          Contattaci
        </a>
      </div>
    </div>
  </section>

  <!-- RECUPERO PUNTI -->
  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">
        {praticheData.points.title}
      </h2>

      <div class="mt-6 space-y-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
        <p>{praticheData.points.body}</p>
      </div>

      <div class="mt-8">
        <a
          href={praticheData.points.cta}
          class="btn-racing-primary"
          data-track="cta_click"
          data-location="pratiche"
          data-section="points"
        >
          Contattaci
        </a>
      </div>
    </div>
  </section>

  <!-- CTA FINALE -->
  <section class="section">
    <div class="container max-w-4xl text-center">
      <h2 class="text-3xl font-bold">
        {praticheData.final.title}
      </h2>

      <p class="mx-auto mt-4 max-w-3xl text-base md:text-lg leading-7 md:leading-8 text-black/70">
        {praticheData.final.body}
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-4 md:flex-row">
        {praticheData.final.ctas.map((cta) => (
          <a
            href={cta.href}
            class="btn-racing-primary"
            data-track={cta.href.startsWith("https://wa.me/") ? "whatsapp_click" : "cta_click"}
            data-location="pratiche"
            data-section="final"
          >
            {cta.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
