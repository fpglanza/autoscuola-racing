---
import BaseLayout from "../layouts/BaseLayout.astro";
import { praticheData } from "../data/pratiche";
import PageHero from "../components/ui/PageHero.astro";
---

<BaseLayout title="Pratiche e rinnovi">
  <!-- HERO -->
  <PageHero
    label="Pratiche"
    heading={praticheData.hero.heading}
    intro={praticheData.hero.intro}
    primaryCta={praticheData.hero.cta}
  />

  <!-- RINNOVO -->
  <section class="section">
    <div class="container max-w-4xl">
      <h2 class="text-3xl font-bold">
        {praticheData.renewal.title}
      </h2>

      <p class="mt-4 text-base md:text-lg text-black/70">
        {praticheData.renewal.body}
      </p>

      <div class="mt-6 grid gap-4">
        {praticheData.renewal.items.map((item) => (
          <div class="border border-black/10 rounded-2xl p-4 text-sm text-black/70">
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CASI SPECIALI -->
  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-2xl font-bold">
        {praticheData.medical.title}
      </h2>

      <p class="mt-4 text-base text-black/70">
        {praticheData.medical.body}
      </p>
    </div>
  </section>

  <!-- DUPLICATI -->
  <section class="section">
    <div class="container max-w-4xl">
      <h2 class="text-2xl font-bold">
        {praticheData.duplicates.title}
      </h2>

      <div class="mt-6 grid gap-4">
        {praticheData.duplicates.items.map((item) => (
          <div class="border border-black/10 rounded-2xl p-4 text-sm text-black/70">
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RECUPERO PUNTI -->
  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-2xl font-bold">
        {praticheData.points.title}
      </h2>

      <p class="mt-4 text-base text-black/70">
        {praticheData.points.body}
      </p>
    </div>
  </section>

  <!-- CTA FINALE -->
  <section class="section">
    <div class="container max-w-3xl text-center">
      <h2 class="text-3xl font-bold">
        {praticheData.final.title}
      </h2>

      <p class="mt-4 text-base text-black/70">
        {praticheData.final.body}
      </p>

      <div class="mt-8 flex flex-col gap-4 md:flex-row md:justify-center">
        {praticheData.final.ctas.map((cta) => (
          <a href={cta.href} class="btn-racing-primary">
            {cta.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>