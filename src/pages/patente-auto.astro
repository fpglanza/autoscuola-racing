---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../lib/content";
import { patenteAutoData } from "../data/patente-auto";
import PageHero from "../components/ui/PageHero.astro";

const page = await getPageContent("patente-auto");
const { title, description } = page.data;

const pathItems = patenteAutoData.path.items.map((item) => {
  const [rawTitle, ...rest] = item.split(":");
  return {
    title: rawTitle?.trim() ?? "",
    body: rest.join(":").trim(),
  };
});
---

<BaseLayout title={title} description={description}>
  <!-- HERO -->
  <PageHero
    label="Patente B"
    heading={patenteAutoData.hero.heading}
    intro={patenteAutoData.hero.intro}
    primaryCta={patenteAutoData.hero.cta}
    placeholderText="Placeholder patente"
  />

    <!-- PERCORSO -->
  <section class="section overflow-hidden">
    <div class="container max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold">
          {patenteAutoData.path.title}
        </h2>
      </div>

      <div class="relative mt-14">
        <div class="absolute left-0 right-0 top-10 hidden border-t border-dashed border-[#12135D]/15 xl:block"></div>

        <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-4 xl:gap-10">
          {pathItems.map((item, index) => (
            <article class="relative text-center">
              <div
                class:list={[
                  "relative z-[1] mx-auto flex h-20 w-20 items-center justify-center rounded-[22px] shadow-[0_20px_50px_rgba(18,19,93,0.12)]",
                  index % 2 === 0
                    ? "bg-[#D4FF00] text-[#12135D]"
                    : "bg-[#12135D] text-white",
                ]}
              >
                {index === 0 && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-9 w-9"
                    aria-hidden="true"
                  >
                    <path d="M4 19h16"></path>
                    <path d="M5 16V8l7-4 7 4v8"></path>
                    <path d="M9 10h6"></path>
                    <path d="M9 13h6"></path>
                  </svg>
                )}

                {index === 1 && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-9 w-9"
                    aria-hidden="true"
                  >
                    <path d="M8 3h6l5 5v13H8a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z"></path>
                    <path d="M14 3v5h5"></path>
                    <path d="M10 13h4"></path>
                    <path d="M10 17h4"></path>
                  </svg>
                )}

                {index === 2 && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-9 w-9"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="12" r="7"></circle>
                    <path d="M12 9v3l2 2"></path>
                  </svg>
                )}

                {index === 3 && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-9 w-9"
                    aria-hidden="true"
                  >
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <path d="M22 4 12 14.01l-3-3"></path>
                  </svg>
                )}
              </div>

              <h3 class="mt-6 text-xl font-bold text-[#12135D]">
                {item.title}
              </h3>

              <p class="mx-auto mt-3 max-w-[18rem] text-sm leading-7 text-[#2C3E50]/80 md:text-[15px]">
                {item.body}
              </p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- COSTO -->
  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">
        {patenteAutoData.cost.title}
      </h2>

      <div class="mt-6 space-y-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
        {patenteAutoData.cost.body.split("\n").map((p) => (
          <p>{p}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RECUPERO PUNTI -->
  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-2xl font-bold">
        {patenteAutoData.points.title}
      </h2>

      <p class="mt-4 text-base leading-7 text-black/70">
        {patenteAutoData.points.body}
      </p>
    </div>
  </section>

  <!-- SUPPORTO -->
  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">
        {patenteAutoData.support.title}
      </h2>

      <div class="mt-6 space-y-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
        {patenteAutoData.support.body.split("\n").map((p) => (
          <p>{p}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- PROSSIMI PASSI -->
  <section class="section">
    <div class="container max-w-4xl">
      <h2 class="text-3xl font-bold">
        {patenteAutoData.nextSteps.title}
      </h2>

      <p class="mt-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
        {patenteAutoData.nextSteps.body}
      </p>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {patenteAutoData.nextSteps.locations.map((item) => (
          <div class="rounded-2xl border border-black/10 p-4 text-sm text-black/70">
            {item}
          </div>
        ))}
      </div>

      <div class="mt-8 flex flex-col gap-4 md:flex-row">
        {patenteAutoData.nextSteps.ctas.map((cta) => (
          <a href={cta.href} class="btn-racing-primary">
            {cta.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">
        FAQ – Tutto quello che devi sapere
      </h2>

      <div class="mt-8 space-y-4">
        {patenteAutoData.faq.map((item, i) => (
          <div class="border border-black/10 rounded-2xl">
            <button
              class="w-full text-left p-4 font-medium flex justify-between items-center"
              data-faq-toggle={i}
            >
              <span>{item.question}</span>
              <span>+</span>
            </button>

            <div
              class="hidden px-4 pb-4 text-sm text-black/70"
              data-faq-content={i}
            >
              {item.answer}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const toggles = document.querySelectorAll("[data-faq-toggle]");

  toggles.forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-faq-toggle");
      const content = document.querySelector(
        `[data-faq-content="${id}"]`
      );

      content.classList.toggle("hidden");
    });
  });
</script>