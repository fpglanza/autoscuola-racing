---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../lib/content";
import { patenteAutoData } from "../data/patente-auto";
import autoHeroBg from "../assets-optimized/logo/Auto (sfondo con overlay).webp";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import ragazzaPatenteImg from "../assets-optimized/logo/Ragazza patente B.webp";
import taglioLuceImg from "../assets-optimized/logo/Taglio di luce.webp";

const page = await getPageContent("patente-auto");
const { title, description } = page.data;

const pathItems = patenteAutoData.path.items.map((item) => {
  const [rawTitle, ...rest] = item.split(":");
  return {
    title: rawTitle?.trim() ?? "",
    body: rest.join(":").trim(),
  };
});
---

<BaseLayout title={title} description={description} breadcrumbs={false}>
  <!-- HERO -->
  <section class="relative min-h-screen w-full overflow-hidden bg-[#05091f]">
    <img
      src={autoHeroBg.src}
      alt="Patente auto Autoscuola Racing"
      class="absolute inset-0 h-full w-full object-cover"
    />

    <!-- Overlay coerente con homepage -->
    <div class="absolute inset-0 hero-overlay-main"></div>

    <!-- Overlay laterale per leggibilità testo a sinistra -->
    <div class="absolute inset-0 hero-overlay-side"></div>

    <div class="relative z-10 flex min-h-screen items-center">
      <div class="container">
        <div class="max-w-3xl pt-28 pb-16 text-left">
          <h1 class="!mb-3 !block !font-body !text-[10px] !font-bold !not-italic !uppercase !leading-none !tracking-[0.18em] !text-white/80 ![text-shadow:none] md:!text-xs">
            Patente B a Mestre e Salzano
          </h1>

          <h2 class="heading-hero text-left text-[clamp(2.7rem,6vw,6rem)]">

            {patenteAutoData.hero.heading}

          </h2>

          <div class="mt-6 max-w-2xl text-left text-sm leading-6 text-white/85 md:text-base md:leading-7">
            <p>{patenteAutoData.hero.intro}</p>
          </div>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href={patenteAutoData.hero.cta.href}
              class="btn-racing-lime"
              data-track="cta_click"
              data-location="patente-auto"
              data-section="hero"
            >
              {patenteAutoData.hero.cta.label}
            </a>

            <a
              href="#percorso"
              class="btn-racing-ghost-lime"
              data-track="cta_click"
              data-location="patente-auto"
              data-section="hero"
            >
              scopri il percorso
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Breadcrumbs />

    <!-- PERCORSO -->
  <section id="percorso" class="section scroll-mt-[150px] overflow-hidden">
    <div class="container max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold">
          {patenteAutoData.path.title}
        </h2>
      </div>

      <div class="relative mt-14">
        <div class="absolute left-0 right-0 top-10 hidden border-t border-dashed border-[#12135D]/15 xl:block"></div>

        <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-4 xl:gap-10">
          {pathItems.map((item, index) => (
            <article class="relative text-center">
              <div
                class:list={[
                  "relative z-[1] mx-auto flex h-20 w-20 items-center justify-center rounded-[22px] shadow-[0_20px_50px_rgba(18,19,93,0.12)]",
                  index % 2 === 0
                    ? "bg-[#D4FF00] text-[#12135D]"
                    : "bg-[#12135D] text-white",
                ]}
              >
                {index === 0 && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-9 w-9"
                    aria-hidden="true"
                  >
                    <path d="M4 19h16"></path>
                    <path d="M5 16V8l7-4 7 4v8"></path>
                    <path d="M9 10h6"></path>
                    <path d="M9 13h6"></path>
                  </svg>
                )}

                {index === 1 && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-9 w-9"
                    aria-hidden="true"
                  >
                    <path d="M8 3h6l5 5v13H8a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z"></path>
                    <path d="M14 3v5h5"></path>
                    <path d="M10 13h4"></path>
                    <path d="M10 17h4"></path>
                  </svg>
                )}

                {index === 2 && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-9 w-9"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="12" r="7"></circle>
                    <path d="M12 9v3l2 2"></path>
                  </svg>
                )}

                {index === 3 && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-9 w-9"
                    aria-hidden="true"
                  >
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <path d="M22 4 12 14.01l-3-3"></path>
                  </svg>
                )}
              </div>

              <h3 class="mt-6 text-xl font-bold text-[#12135D]">
                {item.title}
              </h3>

              <p class="mx-auto mt-3 max-w-[18rem] text-sm leading-7 text-[#2C3E50]/80 md:text-[15px]">
                {item.body}
              </p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

<!-- COSTI, RECUPERO PUNTI E SUPPORTO -->
<section class="relative overflow-hidden bg-[var(--color-secondary)] py-24 text-white md:py-32">
  <img
    src={taglioLuceImg.src}
    alt="Dettaglio luce Autoscuola Racing"
    class="absolute inset-0 h-full w-full object-cover opacity-45"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 bg-[var(--color-secondary)]/82"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-secondary)]/75 via-[var(--color-secondary)]/85 to-[var(--color-secondary)]"></div>

  <!-- Decorazioni -->
  <div class="absolute -left-24 top-16 h-72 w-72 rounded-full bg-[var(--color-primary)]/15 blur-3xl"></div>
  <div class="absolute -right-24 bottom-16 h-72 w-72 rounded-full bg-[var(--color-primary)]/10 blur-3xl"></div>

  <div class="container relative z-10 max-w-7xl">

    <!-- HEADER ORIZZONTALE -->
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <div>
        <p class="mb-4 text-xs uppercase tracking-[0.25em] text-white/45">
          costi, punti e supporto
        </p>

        <h2 class="max-w-3xl text-[34px] uppercase leading-[0.9] text-[var(--color-primary)] md:text-[52px]">
          Prima di iniziare, facciamo chiarezza.
        </h2>
      </div>

      <div class="max-w-2xl lg:ml-auto">
        <p class="text-base leading-7 text-white/78 md:text-lg md:leading-8">
          La patente non è solo una pratica da completare. È un percorso fatto di costi,
          tempi, preparazione e fiducia. Per questo ti spieghiamo tutto prima, senza sorprese.
        </p>

        <div class="mt-7 flex flex-col gap-4 sm:flex-row">
          <a
            href={patenteAutoData.hero.cta.href}
            class="btn-racing-lime"
            data-track="cta_click"
            data-location="patente-auto"
            data-section="clarity"
          >
            {patenteAutoData.hero.cta.label}
          </a>

          <a
            href="#prossimi-passi"
            class="btn-racing-ghost-lime"
            data-track="cta_click"
            data-location="patente-auto"
            data-section="clarity"
          >
            parla con noi
          </a>
        </div>
      </div>
    </div>

    <!-- CARD ORIZZONTALI -->
    <div class="mt-14 grid gap-6 lg:grid-cols-3">

      <!-- COSTO -->
      <article class="group relative flex min-h-[420px] flex-col overflow-hidden rounded-[36px] border border-white/10 bg-white/[0.06] p-7 shadow-[0_24px_65px_rgba(0,0,0,0.18)] transition-all duration-300 hover:-translate-y-1 md:p-8">
        <div class="mb-8 flex items-center justify-between">
          <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary)] text-lg font-bold text-[var(--color-secondary)]">
            01
          </span>
          <span class="ml-5 h-px flex-1 bg-white/15"></span>
        </div>

        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/40">
          investimento
        </p>

        <h3 class="mt-4 text-2xl font-bold uppercase leading-tight text-white md:text-[28px]">
          {patenteAutoData.cost.title}
        </h3>

        <div class="mt-5 space-y-4 text-sm leading-7 text-white/72 md:text-[15px]">
          {patenteAutoData.cost.body.split("\n").map((p) => (
            <p>{p}</p>
          ))}
        </div>

        <div class="mt-auto pt-8">
          <a
            href="#prossimi-passi"
            class="inline-flex text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-primary)] transition hover:text-white"
            data-track="cta_click"
            data-location="patente-auto"
            data-section="cost"
          >
            chiedi un preventivo →
          </a>
        </div>
      </article>

      <!-- CQC -->
      <article class="group relative flex min-h-[420px] flex-col overflow-hidden rounded-[36px] border border-[var(--color-primary)]/20 bg-white/[0.095] p-7 shadow-[0_24px_65px_rgba(0,0,0,0.22)] transition-all duration-300 hover:-translate-y-1 md:p-8">
        <div class="mb-8 flex items-center justify-between">
          <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary)]/85 text-lg font-bold text-[var(--color-secondary)]">
            02
          </span>
          <span class="ml-5 h-px flex-1 bg-white/15"></span>
        </div>

        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/40">
          sei un conducente professionale?
        </p>

        <h3 class="mt-4 text-2xl font-bold uppercase leading-tight text-white md:text-[28px]">
          {patenteAutoData.points.title}
        </h3>

        <p class="mt-5 text-sm leading-7 text-white/72 md:text-[15px]">
          {patenteAutoData.points.body}
        </p>

        <div class="mt-auto pt-8">
          <a
            href="#prossimi-passi"
            class="inline-flex text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-primary)] transition hover:text-white"
            data-track="cta_click"
            data-location="patente-auto"
            data-section="points"
          >
            chiedi info rinnovo CQC →
          </a>
        </div>
      </article>

      <!-- SUPPORTO -->
      <article class="group relative flex min-h-[420px] flex-col overflow-hidden rounded-[36px] border border-[var(--color-primary)]/35 bg-[linear-gradient(145deg,rgba(212,255,0,0.20),rgba(27,28,104,0.96)_42%,rgba(18,19,93,0.96))] p-7 text-white shadow-[0_24px_65px_rgba(0,0,0,0.24)] transition-all duration-300 hover:-translate-y-1 md:p-8">        <div class="absolute -right-20 -bottom-20 h-52 w-52 rounded-full bg-[var(--color-primary)]/20 blur-3xl"></div>
        <div class="relative z-10 mb-8 flex items-center justify-between">
          <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-[var(--color-secondary)] text-lg font-bold text-[var(--color-primary)]">
            03
          </span>
          <span class="ml-5 h-px flex-1 bg-white/15"></span>
        </div>

        <div class="relative z-10">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/45">
            metodo racing
          </p>

          <h3 class="mt-4 text-2xl font-bold uppercase leading-tight text-[var(--color-primary)] md:text-[28px]">
            {patenteAutoData.support.title}
          </h3>

          <div class="mt-5 space-y-4 text-sm leading-7 text-white/76 md:text-[15px]">
            {patenteAutoData.support.body.split("\n").map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </div>

        <div class="relative z-10 mt-auto pt-8">
          <a
            href={patenteAutoData.hero.cta.href}
            class="btn-racing-lime"
            data-track="cta_click"
            data-location="patente-auto"
            data-section="support"
          >
            inizia con il metodo giusto
          </a>
        </div>
      </article>

    </div>
  </div>
</section>
  
  <!-- PROSSIMI PASSI -->
  <section id="prossimi-passi" class="relative scroll-mt-[50px] overflow-hidden bg-[#F8F9FF] py-24 md:py-32">
    <div class="container max-w-6xl">
      <div class="grid gap-14 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">

        <!-- INTRO + IMMAGINE -->
        <div class="lg:sticky lg:top-32">
          <p class="mb-4 text-xs uppercase tracking-[0.25em] text-[var(--color-secondary)]/45">
            prossimi passi
          </p>

          <h2 class="text-[34px] uppercase leading-[0.9] text-[var(--color-secondary)] md:text-[52px]">
            {patenteAutoData.nextSteps.title}
          </h2>

          <p class="mt-7 text-base leading-7 text-[var(--color-text)]/80 md:text-lg md:leading-8">
            {patenteAutoData.nextSteps.body}
          </p>

          <div class="mt-9 flex flex-col gap-4 sm:flex-row lg:flex-col">
            {patenteAutoData.nextSteps.ctas.map((cta, index) => (
              <a
                href={cta.href}
                class={index === 0 ? "btn-racing-primary" : "btn-secondary"}
                data-track={cta.href.startsWith("https://wa.me/") ? "whatsapp_click" : "cta_click"}
                data-location="patente-auto"
                data-section="next-steps"
              >
                {cta.label}
              </a>
            ))}
          </div>

          <div class="mt-10 overflow-hidden rounded-[36px] shadow-[0_24px_60px_rgba(18,19,93,0.16)]">
            <img
              src={ragazzaPatenteImg.src}
              alt="Ragazza con patente B Autoscuola Racing"
              class="h-[360px] w-full object-cover md:h-[440px] lg:h-[500px]"
            />
          </div>
        </div>

        <!-- CONTENT -->
        <div class="space-y-6">

          <!-- SEDI -->
          <div class="grid gap-6 md:grid-cols-2">
            <article class="group relative overflow-hidden rounded-[32px] bg-white p-7 shadow-[0_18px_45px_rgba(18,19,93,0.08)] transition-all duration-300 hover:-translate-y-1">
              <div class="mb-8 flex items-center justify-between">
                <span class="flex h-14 w-14 items-center justify-center rounded-full bg-[var(--color-primary)] text-[var(--color-secondary)] shadow-[0_14px_28px_rgba(18,19,93,0.12)]">
                  01
                </span>
                <span class="ml-5 h-px flex-1 bg-black/10"></span>
              </div>

              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-secondary)]/45">
                Sede di Favaro Veneto
              </p>

              <div class="mt-5 space-y-3 text-base leading-7 text-[var(--color-text)]/80">
                <p>
                  <strong class="text-[var(--color-secondary)]">Indirizzo:</strong><br />
                  Via M.te Cervino, 23/a<br />
                  30173 Favaro Veneto (VE)
                </p>

                <p>
                  <strong class="text-[var(--color-secondary)]">Telefono:</strong><br />
                  <a
                    href="tel:+39041630163"
                    class="font-semibold hover:text-[var(--color-primary)]"
                    data-track="phone_click"
                    data-location="favaro"
                    data-section="next-steps"
                  >
                    +39 041 630163
                  </a>
                </p>

                <p>
                  <strong class="text-[var(--color-secondary)]">Per:</strong><br />
                  Iscrizioni, corsi patente B, quiz e pratiche in sede.
                </p>
              </div>
            </article>

            <article class="group relative overflow-hidden rounded-[32px] bg-white p-7 shadow-[0_18px_45px_rgba(18,19,93,0.08)] transition-all duration-300 hover:-translate-y-1">
              <div class="mb-8 flex items-center justify-between">
                <span class="flex h-14 w-14 items-center justify-center rounded-full bg-[var(--color-secondary)] text-[var(--color-primary)] shadow-[0_14px_28px_rgba(18,19,93,0.12)]">
                  02
                </span>
                <span class="ml-5 h-px flex-1 bg-black/10"></span>
              </div>

              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-secondary)]/45">
                Sede di Salzano
              </p>

              <div class="mt-5 space-y-3 text-base leading-7 text-[var(--color-text)]/80">
                <p>
                  <strong class="text-[var(--color-secondary)]">Indirizzo:</strong><br />
                  Via A. De Gasperi, 84<br />
                  30030 Salzano (VE)
                </p>

                <p>
                  <strong class="text-[var(--color-secondary)]">Telefono:</strong><br />
                  <a
                    href="tel:+390415746510"
                    class="font-semibold hover:text-[var(--color-primary)]"
                    data-track="phone_click"
                    data-location="salzano"
                    data-section="next-steps"
                  >
                    +39 041 5746510
                  </a>
                </p>

                <p>
                  <strong class="text-[var(--color-secondary)]">Per:</strong><br />
                  Iscrizioni, supporto diretto e percorso patente B.
                </p>
              </div>
            </article>
          </div>

          <!-- COSA PORTARE -->
          <article class="relative overflow-hidden rounded-[36px] bg-white p-8 shadow-[0_18px_45px_rgba(18,19,93,0.08)] md:p-10">
            <div class="absolute -right-16 -top-16 h-40 w-40 rounded-full bg-[var(--color-primary)]/30 blur-2xl"></div>

            <div class="relative z-10">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-secondary)]/45">
                Come iniziare
              </p>

              <h3 class="mt-4 text-2xl font-bold uppercase leading-tight text-[var(--color-secondary)] md:text-3xl">
                Vieni in sede o scrivici: ti spieghiamo tutto senza complicazioni.
              </h3>

              <p class="mt-5 text-base leading-7 text-[var(--color-text)]/80 md:text-lg md:leading-8">
                Ti aiutiamo a capire documenti necessari, calendario delle lezioni, costi e prossime disponibilità.
                L’obiettivo è farti partire con un percorso chiaro, ordinato e adatto ai tuoi tempi.
              </p>
            </div>
          </article>

        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">
        FAQ – Tutto quello che devi sapere
      </h2>

      <div class="mt-8 space-y-4">
        {patenteAutoData.faq.map((item, i) => (
          <div class="border border-black/10 rounded-2xl">
            <button
              class="w-full text-left p-4 font-medium flex justify-between items-center"
              data-faq-toggle={i}
            >
              <span>{item.question}</span>
              <span>+</span>
            </button>

            <div
              class="hidden px-4 pb-4 text-sm text-black/70"
              data-faq-content={i}
            >
              {item.answer}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const toggles = document.querySelectorAll("[data-faq-toggle]");

  toggles.forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-faq-toggle");
      const content = document.querySelector(
        `[data-faq-content="${id}"]`
      );

      content.classList.toggle("hidden");
    });
  });
</script>
