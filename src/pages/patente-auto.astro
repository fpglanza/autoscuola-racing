---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../lib/content";

const page = await getPageContent("patente-auto");
const { title, description, heading, intro } = page.data;
---

<BaseLayout title={title} description={description}>
  <section class="section">
    <div class="container max-w-4xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-black/60">Patente Auto</p>
      <h1 class="mt-4 text-4xl font-bold leading-tight md:text-5xl">{heading}</h1>
      <p class="mt-6 text-lg leading-8 text-black/70">{intro}</p>
    </div>
  </section>

  <section class="section section-light">
    <div class="container grid gap-6 md:grid-cols-3">
      <div class="rounded-3xl bg-white p-6">
        <h2 class="text-lg font-bold">Teoria</h2>
        <p class="mt-3 text-sm leading-6 text-black/70">
          Lezioni e supporto per capire i concetti, non solo memorizzare quiz.
        </p>
      </div>
      <div class="rounded-3xl bg-white p-6">
        <h2 class="text-lg font-bold">Guida</h2>
        <p class="mt-3 text-sm leading-6 text-black/70">
          Un accompagnamento pratico graduale, con attenzione alla sicurezza e alla consapevolezza.
        </p>
      </div>
      <div class="rounded-3xl bg-white p-6">
        <h2 class="text-lg font-bold">Esame</h2>
        <p class="mt-3 text-sm leading-6 text-black/70">
          L’obiettivo è arrivare al momento dell’esame con solidità, non con fretta.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>