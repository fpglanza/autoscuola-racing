---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../lib/content";
import { contattiData } from "../data/contatti";
import PageHero from "../components/ui/PageHero.astro";
import InfoCard from "../components/ui/InfoCard.astro";

const page = await getPageContent("contatti");
const { title, description } = page.data;
---

<BaseLayout title={title} description={description}>
  <PageHero
    label="Contatti"
    heading={contattiData.hero.heading}
    intro={contattiData.hero.intro}
    placeholderText="Placeholder contatti / sedi"
  />

  <section class="section section-light">
    <div class="container">
      <div class="grid gap-6 md:grid-cols-2">
        <article class="rounded-3xl bg-white p-6">
          <h2 class="text-2xl font-bold">{contattiData.favaro.title}</h2>
          <p class="mt-4 text-base leading-7 text-black/70">
            {contattiData.favaro.body}
          </p>

          <div class="mt-6 space-y-3">
            {contattiData.favaro.details.map((item) => (
              <div class="rounded-2xl border border-black/10 p-4 text-sm text-black/70">
                {item}
              </div>
            ))}
          </div>
        </article>

        <article class="rounded-3xl bg-white p-6">
          <h2 class="text-2xl font-bold">{contattiData.salzano.title}</h2>
          <p class="mt-4 text-base leading-7 text-black/70">
            {contattiData.salzano.body}
          </p>

          <div class="mt-6 space-y-3">
            {contattiData.salzano.details.map((item) => (
              <div class="rounded-2xl border border-black/10 p-4 text-sm text-black/70">
                {item}
              </div>
            ))}
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-4xl">
      <h2 class="text-3xl font-bold">{contattiData.hours.title}</h2>
      <p class="mt-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
        {contattiData.hours.body}
      </p>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {contattiData.hours.items.map((item) => (
          <div class="rounded-2xl border border-black/10 p-4 text-sm font-medium text-black/70">
            {item}
          </div>
        ))}
      </div>

      <p class="mt-8 text-base leading-7 text-black/70">
        {contattiData.hours.note}
      </p>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="max-w-4xl">
        <h2 class="text-3xl font-bold">{contattiData.whatsapp.title}</h2>
        <p class="mt-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
          {contattiData.whatsapp.body}
        </p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {contattiData.whatsapp.items.map((item) => (
          <InfoCard
            title={item.label}
            text=""
            href={item.href}
            ctaLabel={item.cta}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>