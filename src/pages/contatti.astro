---
import BaseLayout from "../layouts/BaseLayout.astro";
import LocationCard from "../components/ui/LocationCard.astro";
import { locations } from "../data/locations";
---

<BaseLayout
  title="Contatti | Autoscuola Racing"
  description="Contatti e sedi Autoscuola Racing a Favaro Veneto e Salzano."
>
  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-black/60">Contatti</p>
        <h1 class="mt-4 text-4xl font-bold leading-tight md:text-5xl">
          Due sedi, riferimenti chiari, un contatto semplice.
        </h1>
        <p class="mt-6 text-lg leading-8 text-black/70">
          Per evitare confusione, distinguiamo bene le due sedi. In questa fase mettiamo già la struttura giusta, poi aggiungiamo WhatsApp, orari e form.
        </p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {locations.map((location) => <LocationCard {...location} />)}
      </div>
    </div>
  </section>
</BaseLayout>