---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../lib/content";
import { contattiData } from "../data/contatti";
import { whatsappLink } from "../lib/whatsapp";
import contattiHeroBg from "../assets-optimized/logo/Taglio di luce.webp";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";

const page = await getPageContent("contatti");
const { title, description } = page.data;
---

<BaseLayout title={title} description={description}>
  <!-- HERO -->
  <section class="relative min-h-screen w-full overflow-hidden bg-[#05091f]">
    <img
      src={contattiHeroBg.src}
      alt="Contatti Autoscuola Racing"
      class="absolute inset-0 h-full w-full object-cover"
    />

    <!-- Overlay coerente con homepage -->
    <div class="absolute inset-0 hero-overlay-main"></div>

    <!-- Overlay laterale per leggibilità testo a sinistra -->
    <div class="absolute inset-0 hero-overlay-side"></div>

    <!-- Luce decorativa -->
    <div class="absolute -left-24 top-24 h-72 w-72 rounded-full bg-[var(--color-primary)]/15 blur-3xl"></div>
    <div class="absolute -right-24 bottom-20 h-72 w-72 rounded-full bg-[var(--color-primary)]/10 blur-3xl"></div>

    <div class="relative z-10 flex min-h-screen items-center">
      <div class="container">
        <div class="max-w-3xl pt-28 pb-16 text-left">
          <p class="mb-3 text-[10px] font-bold uppercase leading-none tracking-[0.18em] text-white/80 md:text-xs">
            Contatti
          </p>

          <h1 class="heading-hero text-left text-[clamp(2.7rem,6vw,6rem)]">
            {contattiData.hero.heading}
          </h1>

          <div class="mt-6 max-w-2xl text-left text-sm leading-6 text-white/85 md:text-base md:leading-7">
            <p>{contattiData.hero.intro}</p>
          </div>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href="#sedi"
              class="btn-racing-lime"
              data-track="cta_click"
              data-location="contatti"
              data-section="hero"
            >
              scegli la sede
            </a>

            <a
              href="#visite-mediche"
              class="btn-racing-ghost-lime"
              data-track="cta_click"
              data-location="contatti"
              data-section="hero"
            >
              visite mediche
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Breadcrumbs />
  <!-- SEDI -->
  <section id="sedi" class="section section-light scroll-mt-[140px] overflow-hidden">
    <div class="container max-w-6xl">
      <div class="grid gap-6 xl:grid-cols-2">
        <article class="overflow-hidden rounded-[32px] border border-[#12135D]/10 bg-white shadow-[0_20px_50px_rgba(18,19,93,0.08)]">
          <div class="h-2 w-full bg-[#D4FF00]"></div>

          <div class="p-6 md:p-8">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#2124BD]">
                  Sede
                </p>

                <h2 class="mt-3 text-2xl font-bold text-[#12135D] md:text-3xl">
                  {contattiData.favaro.title}
                </h2>
              </div>

              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[#12135D] text-white shadow-[0_16px_35px_rgba(18,19,93,0.18)]">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-7 w-7"
                  aria-hidden="true"
                >
                  <path d="M12 21s-6-5.33-6-11a6 6 0 1 1 12 0c0 5.67-6 11-6 11Z"></path>
                  <circle cx="12" cy="10" r="2.5"></circle>
                </svg>
              </div>
            </div>

            <p class="mt-5 text-base leading-7 text-black/70">
              {contattiData.favaro.body}
            </p>

            <div class="mt-8 space-y-4">
              <div class="rounded-[22px] border border-[#12135D]/10 bg-[#F8F9FF] p-4">                <p class="text-sm leading-7 text-black/70 md:text-[15px]">
                  <strong class="text-[#12135D]">Indirizzo:</strong> {contattiData.favaro.address}
                </p>
              </div>

              <div class="rounded-[22px] border border-[#12135D]/10 bg-[#F8F9FF] p-4">                <p class="text-sm leading-7 text-black/70 md:text-[15px]">
                  <strong class="text-[#12135D]">Telefono:</strong> {contattiData.favaro.phone}
                </p>
              </div>

              <div class="rounded-[22px] border border-[#12135D]/10 bg-[#F8F9FF] p-4">                <p class="text-sm leading-7 text-black/70 md:text-[15px]">
                  <strong class="text-[#12135D]">Email:</strong> {contattiData.favaro.email}
                </p>
              </div>

              <div class="rounded-[22px] border border-[#12135D]/10 bg-[#F8F9FF] p-4">                <p class="text-sm leading-7 text-black/70 md:text-[15px]">
                  <strong class="text-[#12135D]">Orari:</strong> {contattiData.favaro.hours}
                </p>
              </div>
            </div>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
              {contattiData.favaro.actions.map((action) => (
                <a
                  href={action.href}
                  class={action.variant === "primary" ? "btn-racing-primary" : "btn-secondary"}
                  data-track={action.href.startsWith("https://wa.me/") ? "whatsapp_click" : "phone_click"}
                  data-location="favaro"
                  data-section="locations"
                >
                  {action.label}
                </a>
              ))}
            </div>
          </div>
        </article>

        <article class="overflow-hidden rounded-[32px] border border-[#12135D]/10 bg-white shadow-[0_20px_50px_rgba(18,19,93,0.08)]">
          <div class="h-2 w-full bg-[#12135D]"></div>

          <div class="p-6 md:p-8">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#2124BD]">
                  Sede
                </p>

                <h2 class="mt-3 text-2xl font-bold text-[#12135D] md:text-3xl">
                  {contattiData.salzano.title}
                </h2>
              </div>

              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[#D4FF00] text-[#12135D] shadow-[0_16px_35px_rgba(18,19,93,0.12)]">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-7 w-7"
                  aria-hidden="true"
                >
                  <path d="M12 21s-6-5.33-6-11a6 6 0 1 1 12 0c0 5.67-6 11-6 11Z"></path>
                  <circle cx="12" cy="10" r="2.5"></circle>
                </svg>
              </div>
            </div>

            <p class="mt-5 text-base leading-7 text-black/70">
              {contattiData.salzano.body}
            </p>

            <div class="mt-8 space-y-4">
              <div class="rounded-[22px] border border-[#12135D]/10 bg-[#F8F9FF] p-4">                <p class="text-sm leading-7 text-black/70 md:text-[15px]">
                  <strong class="text-[#12135D]">Indirizzo:</strong> {contattiData.salzano.address}
                </p>
              </div>

              <div class="rounded-[22px] border border-[#12135D]/10 bg-[#F8F9FF] p-4">                <p class="text-sm leading-7 text-black/70 md:text-[15px]">
                  <strong class="text-[#12135D]">Telefono:</strong> {contattiData.salzano.phone}
                </p>
              </div>

              <div class="rounded-[22px] border border-[#12135D]/10 bg-[#F8F9FF] p-4">                <p class="text-sm leading-7 text-black/70 md:text-[15px]">
                  <strong class="text-[#12135D]">Email:</strong> {contattiData.salzano.email}
                </p>
              </div>

              <div class="rounded-[22px] border border-[#12135D]/10 bg-[#F8F9FF] p-4">                <p class="text-sm leading-7 text-black/70 md:text-[15px]">
                  <strong class="text-[#12135D]">Orari:</strong> {contattiData.salzano.hours}
                </p>
              </div>
            </div>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
              {contattiData.salzano.actions.map((action) => (
                <a
                  href={action.href}
                  class={action.variant === "primary" ? "btn-racing-primary" : "btn-secondary"}
                  data-track={action.href.startsWith("https://wa.me/") ? "whatsapp_click" : "phone_click"}
                  data-location="salzano"
                  data-section="locations"
                >
                  {action.label}
                </a>
              ))}
            </div>
          </div>
        </article>
      </div>

      <div id="visite-mediche" class="mx-auto mt-10 max-w-4xl scroll-mt-[140px] rounded-[28px] border border-[#12135D]/10 bg-white p-6 text-center shadow-[0_18px_45px_rgba(18,19,93,0.06)] md:p-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#12135D]">
          Visite mediche in sede
        </h2>

        <p class="mt-4 text-base leading-7 text-black/70 md:text-lg md:leading-8">
          {contattiData.medicalNote}
        </p>

        <div class="mt-8 flex flex-col items-center gap-4 md:flex-row md:justify-center">
          <a
            href="/contatti"
            class="btn-racing-primary"
            data-track="cta_click"
            data-location="contatti"
            data-section="medical"
          >
            Prenota la prossima visita
          </a>

          <a
            href={whatsappLink(
              "393494157836",
              "Ciao Autoscuola Racing, vorrei sapere la prossima data disponibile per la visita medica in sede."
            )}
            class="btn-secondary"
            data-track="whatsapp_click"
            data-location="contatti"
            data-section="medical"
          >
            Scrivici su WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
