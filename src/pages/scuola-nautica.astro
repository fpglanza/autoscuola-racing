---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../lib/content";
import { scuolaNauticaData } from "../data/scuola-nautica";

const page = await getPageContent("scuola-nautica");
const { title, description } = page.data;
---

<BaseLayout title={title} description={description}>
  <section class="section">
    <div class="container">
      <div class="grid items-center gap-10 md:grid-cols-2">
        <div>
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-black/60">
            {scuolaNauticaData.hero.label}
          </p>

          <h1 class="max-w-xl text-4xl font-bold leading-tight md:text-5xl">
            {scuolaNauticaData.hero.heading}
          </h1>

          <p class="mt-6 max-w-xl text-lg leading-8 text-black/70">
            {scuolaNauticaData.hero.intro}
          </p>

          <div class="mt-8">
            <a href={scuolaNauticaData.hero.primaryCta.href} class="btn-primary">
              {scuolaNauticaData.hero.primaryCta.label}
            </a>
          </div>
        </div>

        <div class="rounded-3xl bg-[var(--racing-light)] p-10">
          <div class="flex aspect-[4/3] items-center justify-center rounded-2xl border border-dashed border-black/15 bg-white text-center text-black/40">
            Placeholder scuola nautica
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold">{scuolaNauticaData.courses.title}</h2>
        <p class="mt-4 text-lg leading-8 text-black/70">
          {scuolaNauticaData.courses.body}
        </p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {scuolaNauticaData.courses.items.map((item) => (
          <article class="rounded-3xl bg-white p-6">
            <h3 class="text-lg font-bold">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-black/70">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">{scuolaNauticaData.method.title}</h2>
      <p class="mt-4 text-lg leading-8 text-black/70">
        {scuolaNauticaData.method.body}
      </p>
    </div>
  </section>

  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">{scuolaNauticaData.relationship.title}</h2>
      <p class="mt-4 text-lg leading-8 text-black/70">
        {scuolaNauticaData.relationship.body}
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">{scuolaNauticaData.contact.title}</h2>
      <p class="mt-4 text-lg leading-8 text-black/70">
        {scuolaNauticaData.contact.body}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        {scuolaNauticaData.contact.actions.map((action) => (
          <a
            href={action.href}
            class={action.label.includes("contatti") ? "btn-primary" : "btn-secondary"}
          >
            {action.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>