---
import BaseLayout from "../layouts/BaseLayout.astro";
import TeamCard from "../components/ui/TeamCard.astro";
import { getCollection } from "astro:content";
import { getPageContent } from "../lib/content";
import { chiSiamoData } from "../data/chi-siamo";

const page = await getPageContent("chi-siamo");
const { title, description } = page.data;

const team = (await getCollection("team")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title={title} description={description}>
  <section class="section">
    <div class="container max-w-4xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-black/60">
        {chiSiamoData.hero.label}
      </p>
      <h1 class="mt-4 text-4xl font-bold leading-tight md:text-5xl">
        {chiSiamoData.hero.heading}
      </h1>
      <p class="mt-6 text-lg leading-8 text-black/70">
        {chiSiamoData.hero.intro}
      </p>
    </div>
  </section>

  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">{chiSiamoData.introSection.title}</h2>
      <p class="mt-4 text-lg leading-8 text-black/70">
        {chiSiamoData.introSection.body}
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold">I pilastri del metodo</h2>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {chiSiamoData.pillars.map((item) => (
          <article class="rounded-3xl border border-black/10 bg-white p-6">
            <h3 class="text-lg font-bold">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-black/70">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold">{chiSiamoData.path.title}</h2>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {chiSiamoData.path.steps.map((item) => (
          <article class="rounded-3xl bg-white p-6">
            <h3 class="text-lg font-bold">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-black/70">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">{chiSiamoData.difference.title}</h2>
      <p class="mt-4 text-lg leading-8 text-black/70">
        {chiSiamoData.difference.body}
      </p>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold">{chiSiamoData.teamIntro.title}</h2>
        <p class="mt-4 text-lg leading-8 text-black/70">
          {chiSiamoData.teamIntro.body}
        </p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {team.map((member) => <TeamCard {...member.data} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">{chiSiamoData.cta.title}</h2>
      <p class="mt-4 text-lg leading-8 text-black/70">
        {chiSiamoData.cta.body}
      </p>

      <div class="mt-8">
        <a href={chiSiamoData.cta.primary.href} class="btn-primary">
          {chiSiamoData.cta.primary.label}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>