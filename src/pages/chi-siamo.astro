---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../lib/content";
import { chiSiamoData } from "../data/chi-siamo";
import PageHero from "../components/ui/PageHero.astro";

const page = await getPageContent("chi-siamo");
const { title, description } = page.data;
---

<BaseLayout title={title} description={description}>
  <!-- HERO -->
  <PageHero
    label="Il nostro metodo"
    heading={chiSiamoData.hero.heading}
    intro={chiSiamoData.hero.intro}
    primaryCta={chiSiamoData.hero.cta}
    placeholderText="Placeholder metodo"
  />

  <!-- COME SI PRENDE DAVVERO LA PATENTE -->
  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">
        {chiSiamoData.journey.title}
      </h2>
      <div class="mt-6 space-y-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
        {chiSiamoData.journey.body.split("\n").map((p) => (
          <p>{p}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- STRUTTURA DEL PERCORSO -->
  <section class="section section-light">
    <div class="container max-w-4xl">
      <h2 class="text-3xl font-bold">
        {chiSiamoData.structure.title}
      </h2>

      <div class="mt-8 grid gap-4">
        {chiSiamoData.structure.items.map((item) => (
          <div class="rounded-2xl border border-black/10 p-4 text-base text-black/70">
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- APP -->
  <section class="section">
    <div class="container max-w-4xl">
      <h2 class="text-3xl font-bold">
        {chiSiamoData.app.title}
      </h2>

      <p class="mt-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
        {chiSiamoData.app.body}
      </p>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {chiSiamoData.app.items.map((item) => (
          <div class="rounded-2xl border border-black/10 p-4 text-sm text-black/70">
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SUPPORTO -->
  <section class="section section-light">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">
        {chiSiamoData.support.title}
      </h2>

      <div class="mt-6 space-y-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
        {chiSiamoData.support.body.split("\n").map((p) => (
          <p>{p}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- PRONTO -->
  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold">
        {chiSiamoData.readiness.title}
      </h2>

      <div class="mt-6 space-y-4 text-base md:text-lg leading-7 md:leading-8 text-black/70">
        {chiSiamoData.readiness.body.split("\n").map((p) => (
          <p>{p}</p>
        ))}
      </div>

      <div class="mt-8">
        <a href={chiSiamoData.readiness.cta.href} class="btn-racing-primary">
          {chiSiamoData.readiness.cta.label}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>